#EXTINF:-1 m3u-type="vod" group-title="AR - Action" tvg-logo="https://image.tmdb.org/t/p/w500/rj6gQJf3munMckb05u4OTMe7Ha6.jpg" tvg-name="Commando" tvg-id="10999" tvg-year="1985" tvg-language="en" tvg-rating="6.7" tvg-duration="88" tvg-genre="Action, Aventure, Thriller" tvg-director="Mark L. Lester" tvg-cast="Arnold Schwarzenegger, Rae Dawn Chong, Dan Hedaya, Vernon Wells, James Olson" tvg-plot="Après avoir mené de nombreuses missions périlleuses, le colonel John Matrix, un ancien combattant d’élite, coule des jours heureux avec sa fille Jenny, âgée de 12 ans. Mais le général Arius, dictateur déchu, fait kidnapper celle‐ci et charge Matrix d’assassiner l’actuel Président du Val Verde. Ce qu" tvg-tagline="Peu importe, où, quand et comment, quelqu’un doit payer." tvg-backdrop="https://image.tmdb.org/t/p/w1280/gvao0WZchzudp2oMF5sjgzwHY0q.jpg", Commando (1985)
