#EXTINF:-1 m3u-type="vod" group-title="AR - Comédie" tvg-logo="https://image.tmdb.org/t/p/w500/zNUMU5cwWg4uwhh0dxYO0He6XNx.jpg" tvg-name="هاللو أمريكا" tvg-id="86781" tvg-year="2000" tvg-language="ar" tvg-rating="5.2" tvg-duration="115" tvg-genre="Comédie, Drame" tvg-director="Nader Galal" tvg-cast="عادل إمام, Sherine, Nana, Osama Abbas, Hanem Mohamed" tvg-plot="هالو أمريكا هو فيلم كوميدي مصريالإنتاج 1999 وهو الجزء الثالث من بخيت وعديلة بطولة عادل أمام، شيرين، إيناس مكي، أسامة عباس، إنتاج : مصر للتوزيع، تأليف : لينين الرملي وإخراج : نادرجلال  ويعتبر هذا الجزء الثالث من ثلاثية (بخيت وعديلة)، وتتلخص قصته حول سفر بخيت وعديلة لامريكا والمواقف التي يتعرضان لها، " tvg-tagline="" tvg-backdrop="https://image.tmdb.org/t/p/w1280/8aum31vMXE7nYVtA9c7XWu4GsXN.jpg", هاللو أمريكا (2000)
