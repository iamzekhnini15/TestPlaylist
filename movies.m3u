#EXTINF:-1 m3u-type="vod" group-title="AR - Action" tvg-logo="https://image.tmdb.org/t/p/w500/gjb4xVMld19M5IS4EmgVeX7HuHv.jpg" tvg-name="Rambo" tvg-id="1368" tvg-year="1982" tvg-language="en" tvg-rating="7.5" tvg-duration="97" tvg-genre="Action, Aventure, Thriller, Guerre" tvg-director="Ted Kotcheff" tvg-cast="Sylvester Stallone, Richard Crenna, Brian Dennehy, Bill McKinney, Jack Starrett" tvg-plot="Après la guerre du Viêt Nam à l'issue humiliante pour les États Unis, les vétérans envoyés au combat et salués en héros par l'Amérique de Kennedy sûrs de leur bon droit, pour retrouver une Amérique hippie et moralisatrice sous Johnson et les traités d'assassins, sont laissés pour compte, devenus des" tvg-tagline="« Eux ont versé le premier sang, pas moi ! »" tvg-backdrop="https://image.tmdb.org/t/p/w1280/teCZlGivejMw4rVzyxBSYQNr6XI.jpg", Rambo (1982)
