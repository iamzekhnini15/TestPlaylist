#EXTINF:-1 m3u-type="vod" group-title="AR - Action" tvg-logo="https://image.tmdb.org/t/p/w500/lPXWRrIN1VFA1Ovj2O6164x0C7V.jpg" tvg-name="L'Expert" tvg-id="2636" tvg-year="1994" tvg-language="en" tvg-rating="5.9" tvg-duration="110" tvg-genre="Action, Thriller" tvg-director="Luis Llosa" tvg-cast="Sylvester Stallone, Sharon Stone, James Woods, Rod Steiger, Eric Roberts" tvg-plot="Désireuse de se venger des assassins de ses parents, tués sous ses yeux alors qu'elle n'était qu'une enfant, la troublante May Munro recourt aux services de Ray Quick, ancien membre des Services spéciaux américains." tvg-tagline="Sous la chaleur brûlante de Miami, seul le désir de revanche est plus fort que la passion." tvg-backdrop="https://image.tmdb.org/t/p/w1280/fvBshQMwOnYZdUXySGMdT6LiqsI.jpg", L'Expert (1994)
