#EXTINF:-1 m3u-type="vod" group-title="AR - Animation" tvg-logo="https://image.tmdb.org/t/p/w500/a9J57BvqU1zeig5uUzOrRaXPLnp.jpg" tvg-name="Bambi 2" tvg-id="13205" tvg-year="2006" tvg-language="en" tvg-rating="6.5" tvg-duration="72" tvg-genre="Animation, Drame, Familial" tvg-director="Brian Pimental" tvg-cast="Alexander Gould, Patrick Stewart, Brendon Baerg, Nicky Jones, Andrea Bowen" tvg-plot="Le grand classique se poursuit alors que Bambi retourne dans la forêt avec Panpan, M. Hibou, Fleur et Faline. Bambi retrouve son père, le Grand Prince. Pendant ce qui sera l’aventure de sa vie, ce papa fier réalise qu’il a beaucoup à apprendre de son jeune fils. Célébrez ensemble les liens incassabl" tvg-tagline="Le courage d’un fils. L’amour d’un père." tvg-backdrop="https://image.tmdb.org/t/p/w1280/tyKOUk8qVvwCtfMD2eKRNiiEhcM.jpg", Bambi 2 (2006)
