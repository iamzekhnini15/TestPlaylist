#EXTINF:-1 m3u-type="vod" group-title="AR - Familial" tvg-logo="https://image.tmdb.org/t/p/w500/fU54mG8yvk7VBA6BI6TDeyrzt5d.jpg" tvg-name="Abominable" tvg-id="431580" tvg-year="2019" tvg-language="en" tvg-rating="7.5" tvg-duration="97" tvg-genre="Familial, Animation, Aventure, Comédie, Fantastique" tvg-director="Jill Culton" tvg-cast="Chloe Bennet, Albert Tsai, Eddie Izzard, Tenzing Norgay Trainor, Joseph Izzo" tvg-plot="Tout commence sur le toit d’un immeuble à Shanghai, avec l’improbable rencontre d’une jeune adolescente, l’intrépide Yi avec un jeune Yeti. La jeune fille et ses amis Jin et Peng vont tenter de ramener chez lui celui qu’ils appellent désormais Everest, leur nouvel et étrange ami, afin qu’il puisse r" tvg-tagline="Trouver sa place peut être une aventure extraordinaire." tvg-backdrop="https://image.tmdb.org/t/p/w1280/jXk3ZMq7n4ugOqKYq0CtMn3gia8.jpg", Abominable (2019)
