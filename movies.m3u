#EXTINF:-1 m3u-type="vod" group-title="AR - Drame" tvg-logo="https://image.tmdb.org/t/p/w500/2U4VyrTQARim1cyfBSOL17ndg4H.jpg" tvg-name="إحنا بتوع الأتوبيس" tvg-id="86601" tvg-year="1979" tvg-language="ar" tvg-rating="7.8" tvg-duration="135" tvg-genre="Drame" tvg-director="Hussein Kamal" tvg-cast="عادل إمام, Abdel Moneim Madbouly, Younes Shalaby, Moshira Ismail, Aqeila Rateb" tvg-plot="يستقل جابر (عادل إمام) ومرزوق (عبد المنعم مدبولي) الأتوبيس وتحصل مشاجرة بينهما مع المحصل فيذهبون جميعاً إلى القسم، ويتم الافراج عن المحصل بينما يتم حجزهما عن طريق الخطأ المتعمد بتهمة معاداة نظام الحكم حيث يلجأ بعض الضباط لاحتجاز أي شخص لتقفيل القضايا. ويرسلان للمعتقل ويتعرضان للتعذيب، وينتهي الفيلم " tvg-tagline="" tvg-backdrop="https://image.tmdb.org/t/p/w1280/8TLYPA7CZ87Kfn5NoaYYhKWzl88.jpg", إحنا بتوع الأتوبيس (1979)
