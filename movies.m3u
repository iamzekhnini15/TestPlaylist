#EXTINF:-1 m3u-type="vod" group-title="AR - Drame" tvg-logo="https://image.tmdb.org/t/p/w500/5cfUTKtLYJx8WcTRJII4JRnlg6p.jpg" tvg-name="Rocky" tvg-id="1366" tvg-year="1976" tvg-language="en" tvg-rating="7.8" tvg-duration="119" tvg-genre="Drame" tvg-director="John G. Avildsen" tvg-cast="Sylvester Stallone, Talia Shire, Burt Young, Carl Weathers, Burgess Meredith" tvg-plot="Dans les quartiers populaires de Philadelphie, Rocky Balboa collecte des dettes non payées pour Tony Gazzo, un usurier, et dispute de temps à autre, pour quelques dizaines de dollars, des combats de boxe sous l'appellation de 'l'étalon italien'. Déçu de le voir gâcher son talent, son entraîneur Mick" tvg-tagline="Sa vie est à un million contre un" tvg-backdrop="https://image.tmdb.org/t/p/w1280/bacOuUnRBoAO1NjMfsAGX2EKRrS.jpg", Rocky (1976)
