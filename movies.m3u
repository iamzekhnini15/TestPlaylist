#EXTINF:-1 m3u-type="vod" group-title="AR - Animation" tvg-logo="https://image.tmdb.org/t/p/w500/mQaTaFMu8fr4Y6w8fCfoRU49BVn.jpg" tvg-name="Bambi" tvg-id="3170" tvg-year="1942" tvg-language="en" tvg-rating="7.0" tvg-duration="70" tvg-genre="Animation, Drame, Familial" tvg-director="David Hand" tvg-cast="Donnie Dunagan, Peter Behn, Stan Alexander, Cammie King, Will Wright" tvg-plot="Après que sa vie a été bouleversée, Bambi part explorer les merveilles et les défis des bois avec ses meilleurs amis, Panpan et Fleur, afin de satisfaire sa destinée en tant que prince de la forêt." tvg-tagline="Une belle histoire d'amour." tvg-backdrop="https://image.tmdb.org/t/p/w1280/1ZKHzSGJm0kvlCp4echAOtKnDTm.jpg", Bambi (1942)
