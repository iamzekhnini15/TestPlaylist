#EXTINF:-1 m3u-type="vod" group-title="AR - Action" tvg-logo="https://image.tmdb.org/t/p/w500/5qKham6cfFf6Xq2XA9vHYonYgXy.jpg" tvg-name="L'Aventure intérieure" tvg-id="2614" tvg-year="1987" tvg-language="en" tvg-rating="6.8" tvg-duration="120" tvg-genre="Action, Comédie, Science-Fiction" tvg-director="Joe Dante" tvg-cast="Dennis Quaid, Martin Short, Meg Ryan, Kevin McCarthy, Fiona Lewis" tvg-plot="Forte tête de la marine américaine, le lieutenant Tuck Pendelton se porte volontaire pour une expérience très risquée. Miniaturisé, aux commandes d'un submersible de poche, il va être injecté dans l'organisme d'un lapin. Mais des espions industriels s'emparent de la puce qui peut inverser le process" tvg-tagline="Il y a en Jack Putter un héros qui sommeille." tvg-backdrop="https://image.tmdb.org/t/p/w1280/xnOPVEqZWX8T5YlYzNzMeewtXMd.jpg", L'Aventure intérieure (1987)
