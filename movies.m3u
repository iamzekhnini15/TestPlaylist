#EXTINF:-1 m3u-type="vod" group-title="AR - Animation" tvg-logo="https://image.tmdb.org/t/p/w500/qCoaNNfH6lS7qkZDYhWkQpiQpnM.jpg" tvg-name="Cars 2" tvg-id="49013" tvg-year="2011" tvg-language="en" tvg-rating="6.2" tvg-duration="106" tvg-genre="Animation, Familial, Aventure, Comédie" tvg-director="John Lasseter" tvg-cast="Larry the Cable Guy, Owen Wilson, Michael Caine, Emily Mortimer, Eddie Izzard" tvg-plot="La célèbre voiture de course Flash McQueen et l'incomparable dépanneuse Martin quittent Radiator Springs pour courir le tout premier Grand Prix mondial qui sacrera la voiture la plus rapide du monde. Mais la route est pleine d'imprévus, de déviations et de surprises, surtout lorsque Martin se retrou" tvg-tagline="Reprenez la route !" tvg-backdrop="https://image.tmdb.org/t/p/w1280/4BS8tgBNWg2jPiDlBwM2iJe1xB7.jpg", Cars 2 (2011)
