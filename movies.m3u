#EXTINF:-1 m3u-type="vod" group-title="AR - Animation" tvg-logo="https://image.tmdb.org/t/p/w500/u2zNj2EVWgaFXmWJM0HG5PWbgTM.jpg" tvg-name="Les Aristochats" tvg-id="10112" tvg-year="1970" tvg-language="en" tvg-rating="7.3" tvg-duration="81" tvg-genre="Animation, Comédie, Familial, Aventure" tvg-director="Wolfgang Reitherman" tvg-cast="Phil Harris, Eva Gabor, Sterling Holloway, Scatman Crothers, Paul Winchell" tvg-plot="Au cœur de Paris, une millionnaire excentrique lègue toute sa fortune à sa chatte de haute société et ses trois chatons. L’aventure commence alors que son cupide majordome administre une drogue aux chats en espérant toucher leur héritage. C’est à Thomas O’Malley, le chat de gouttière, et sa bande de" tvg-tagline="Une explosion de joie, de rythme et d’humour." tvg-backdrop="https://image.tmdb.org/t/p/w1280/oM5mMTGBqsmMJO3l5tkQdQ0Xujm.jpg", Les Aristochats (1970)
