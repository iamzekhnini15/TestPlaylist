#EXTINF:-1 m3u-type="vod" group-title="AR - Animation" tvg-logo="https://image.tmdb.org/t/p/w500/xZhAFR0N2r5q7tJNWaBGzHUaeb5.jpg" tvg-name="Raiponce" tvg-id="38757" tvg-year="2010" tvg-language="en" tvg-rating="7.6" tvg-duration="101" tvg-genre="Animation, Familial, Aventure" tvg-director="Byron Howard, Nathan Greno" tvg-cast="Mandy Moore, Zachary Levi, Donna Murphy, Ron Perlman, M.C. Gainey" tvg-plot="Quand le bandit le plus recherché du royaume, Flynn Rider, se cache dans une mystérieuse tour, il est pris en otage par Raiponce, une jolie adolescente avec des cheveux de 20 mètres. La curieuse ravisseuse de Flynn, qui cherche à s’échapper de la tour où elle est enfermée depuis des années, conclut " tvg-tagline="Un cheval, des cheveux !" tvg-backdrop="https://image.tmdb.org/t/p/w1280/cWczNud8Y8i8ab0Z4bxos4myWYO.jpg", Raiponce (2010)
