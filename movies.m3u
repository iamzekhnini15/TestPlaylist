#EXTINF:-1 m3u-type="vod" group-title="AR - Action" tvg-logo="https://image.tmdb.org/t/p/w500/7OUVM57BOCGbhQ6UerNrb9Zar26.jpg" tvg-name="Jason Bourne : L'Héritage" tvg-id="49040" tvg-year="2012" tvg-language="en" tvg-rating="6.2" tvg-duration="136" tvg-genre="Action, Thriller" tvg-director="Tony Gilroy" tvg-cast="Jeremy Renner, Rachel Weisz, Edward Norton, Stacy Keach, Dennis Boutsikaris" tvg-plot="Le programme Treadstone dont Jason était le cobaye n’était que la partie émergée d’une conspiration plus ténébreuse, ourdie par d’autres branches du gouvernement et mettant en jeu d’autres agences de renseignement, d’autres programmes militaires, d’autres laboratoires secrets… De Treadstone est né «" tvg-tagline="Il n'y avait pas qu'un seul agent." tvg-backdrop="https://image.tmdb.org/t/p/w1280/akNBILfG0vh7WhuzjA1bXfrgpYI.jpg", Jason Bourne : L'Héritage (2012)
