#EXTINF:-1 m3u-type="vod" group-title="AR - Crime" tvg-logo="https://image.tmdb.org/t/p/w500/r01JaOjD8imIKPYHw97dsLmrc7A.jpg" tvg-name="Demolition Man" tvg-id="9739" tvg-year="1993" tvg-language="en" tvg-rating="6.8" tvg-duration="115" tvg-genre="Crime, Action, Science-Fiction" tvg-director="Marco Brambilla" tvg-cast="Sylvester Stallone, Wesley Snipes, Sandra Bullock, Nigel Hawthorne, Benjamin Bratt" tvg-plot="En 2032, à San Angeles, une mégalopole californienne où toute violence a été éradiquée, Simon Phoenix, un tueur psychopathe condamné à une longue peine d'hibernation et de rééducation, profite d'une visite médicale pour s'évader. Seul recours pour le neutraliser  : réanimer son ennemi de toujours : " tvg-tagline="Dans le futur, il n'y a pas de place pour les deux." tvg-backdrop="https://image.tmdb.org/t/p/w1280/4pl165EUdvveHCr4J4YcHVA1MnD.jpg", Demolition Man (1993)
