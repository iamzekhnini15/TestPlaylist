#EXTINF:-1 tvg-name="The Silence of the Sea" tvg-logo="https://image.tmdb.org/t/p/w780/aWgFoZ24aO3aDUo9RBWRknGAIUf.jpg" group-title="FR | Autres" tvg-id="1362275" tvg-genre="" tvg-year="1980" tvg-rating="0" tvg-duration="0h30" tvg-director="Philip Bonham-Carter" tvg-cast="Michael Byrne, Kenneth Owens, Hugh Dickson, Lisa Bergmayr, Robert van Kaphengst" plot="🎬 Réalisateur : Philip Bonham-Carter — ⭐ Casting : Michael Byrne, Kenneth Owens, Hugh Dickson, Lisa Bergmayr, Robert van Kaphengst — ⏱ Durée : 0h30",The Silence of the Sea (1980)
