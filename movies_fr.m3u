#EXTINF:-1 tvg-name="Eyes Without a Face" tvg-logo="https://image.tmdb.org/t/p/w780/ouYUwQA6IGx7CrDjWLHV9MEsS8m.jpg" group-title="FR | Crime" tvg-id="1144418" tvg-image="https://image.tmdb.org/t/p/w1280/aBizjlCm7TZsZISTrhSmyQkCdVx.jpg" tvg-genre="Crime, Thriller" tvg-year="2023" tvg-rating="10.0" tvg-duration="0h08" tvg-director="Joshua Brock" tvg-cast="Verity Drew-Firth, Solomon Duplessis, Leon CudnachowskiGulyas" plot="🎬 Réalisateur : Joshua Brock — ⭐ Casting : Verity Drew-Firth, Solomon Duplessis, Leon CudnachowskiGulyas — ⏱ Durée : 0h08 — 📊 Note : 10.0/10 (1 votes)",Eyes Without a Face (2023)
