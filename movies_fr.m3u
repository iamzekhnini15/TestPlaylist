#EXTINF:-1 tvg-name="The Woman in Chains" tvg-logo="https://image.tmdb.org/t/p/w780/4jQORZS44QwlIdcuyurtt0yWpps.jpg" group-title="FR | Drame" tvg-id="1387482" tvg-genre="Drame" tvg-year="1923" tvg-rating="0" tvg-duration="1h10" tvg-director="William P. Burt" tvg-cast="E.K. Lincoln, William H. Tooker, Jean Acker, Martha Mansfield, Joseph Striker" plot="🎬 Réalisateur : William P. Burt — ⭐ Casting : E.K. Lincoln, William H. Tooker, Jean Acker, Martha Mansfield, Joseph Striker — ⏱ Durée : 1h10",The Woman in Chains (1923)
